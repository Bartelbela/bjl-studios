# Copy this file to .env on the dockerbox server and fill in the real values.
# .env is gitignored — never commit real credentials.
#
# The docker-compose stack reads these at `docker compose up -d` time and
# injects them into the bjl-studios-api container.

# Telegram bot token (format: 123456789:ABCdef...)
# Get it from @BotFather when you create the bot.
TG_BOT_TOKEN=

# Telegram chat ID to send contact-form notifications to.
# For group chats: starts with a minus sign (e.g. -1001234567890).
# For direct messages: the numeric user ID.
TG_CHAT_ID=
