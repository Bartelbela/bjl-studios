{
  "name": "bjl-studios",
  "version": "1.0.0",
  "private": true,
  "description": "Marketing site for BJL Studios — Digital agency, Mönchengladbach.",
  "homepage": "https://bjl-studios.de",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bartelbela/bjl-studios.git"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:css\" \"npm:dev:serve\"",
    "dev:css": "tailwindcss -i ./src/styles.css -o ./assets/css/app.css --watch",
    "dev:serve": "http-server . -p 8080 -c-1 --silent",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/styles.css -o ./assets/css/app.css --minify",
    "lint": "npm run lint:format && npm run lint:html",
    "lint:format": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "lint:html": "html-validate index.html datenschutz.html impressum.html",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "node --test \"tests/api/*.test.js\"",
    "test:e2e": "playwright test",
    "lighthouse": "lhci autorun",
    "og": "node scripts/generate-og-image.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@fontsource/archivo-black": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.48.0",
    "concurrently": "^9.0.0",
    "gsap": "^3.15.0",
    "html-validate": "^9.0.0",
    "http-server": "^14.1.1",
    "lenis": "^1.3.23",
    "prettier": "^3.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
